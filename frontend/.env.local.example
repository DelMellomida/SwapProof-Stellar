# SwapProof Frontend Environment Variables

# Google Gemini API Key
# Get your free API key from: https://aistudio.google.com/app/apikey
# This is used for AI Title Optimizer and buyer-side credibility summaries
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# Optional Horizon API URLs for seller wallet activity lookups
VITE_HORIZON_URL_TESTNET=https://horizon-testnet.stellar.org
VITE_HORIZON_URL_MAINNET=https://horizon.stellar.org
