# Network
# "testnet" | "mainnet" - controls RPC URL, contract IDs, and network passphrase
VITE_STELLAR_NETWORK=testnet
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# Soroban RPC
VITE_SOROBAN_RPC_URL_TESTNET=https://soroban-testnet.stellar.org
VITE_SOROBAN_RPC_URL_MAINNET=https://mainnet.sorobanrpc.com

# Horizon API (seller wallet activity signals)
VITE_HORIZON_URL_TESTNET=https://horizon-testnet.stellar.org
VITE_HORIZON_URL_MAINNET=https://horizon.stellar.org

# Contract addresses
# Fill these after deploying via `stellar contract deploy`
VITE_CONTRACT_ID_TESTNET=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_CONTRACT_ID_MAINNET=

# Optional asset contract override for older 3-argument contract deployments.
# Leave these set to the native XLM SAC unless you intentionally escrow another asset.
VITE_ESCROW_ASSET_CONTRACT_ID_TESTNET=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC
VITE_ESCROW_ASSET_CONTRACT_ID_MAINNET=CAS3J7GYLGXMF6TDJBBYYSE3HQ6BBSMLNUQ34T6TZMYMW2EVH34XOWMA

# Legacy alias vars kept for older local setups
VITE_USDC_CONTRACT_ID_TESTNET=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA
VITE_USDC_CONTRACT_ID_MAINNET=CCW67TSZV3SSS2HXMBQ5JFGCKJNOOKNS7LIVMKQHP2ZTIFKB64DNKCP
